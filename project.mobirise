                "margin-bottom": "0rem"
              },
              "color": "#cbd5e1"
            },
            ".mbr-text": {
              "color": "#bbbbbb",
              "text-align": "left"
            },
            ".soc-item": {
              "display": "flex",
              "align-items": "center",
              "justify-content": "center",
              "border-radius": "50%",
              "background-color": "white",
              "margin-right": "0.5rem",
              "margin-bottom": "1rem",
              "padding": "0.5rem",
