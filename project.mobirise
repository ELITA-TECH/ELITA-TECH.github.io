    "blog-programowaniePLC.html": {
      "settings": {
        "title": "Programowanie PLC – klucz do wydajnej automatyki przemysłowej",
        "order": "14",
        "meta_descr": "Sterowniki PLC są sercem systemów automatyki przemysłowej. Odpowiednio zaprogramowany system zwiększa wydajność produkcji, poprawia bezpieczeństwo i ogranicza koszty serwisowe."
      },
      "components": [
        {
          "alias": false,
