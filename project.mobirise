              },
              "@media (min-width: 992px)": {
                "margin-bottom": "0rem"
              },
              "color": "#cbd5e1"
            },
            ".mbr-text": {
              "color": "#bbbbbb",
              "text-align": "left"
            },
            ".soc-item": {
              "display": "flex",
              "align-items": "center",
