    "blog-instalacje-elektryczne.html": {
      "settings": {
        "title": "Instalacje elektryczne przemysłowe – jak zapewnić bezpieczeństwo i niezawodność?",
        "order": "13",
        "meta_descr": "Instalacje elektryczne w zakładach przemysłowych muszą spełniać rygorystyczne normy bezpieczeństwa. Ich stan techniczny ma bezpośredni wpływ na ciągłość produkcji."
      },
      "components": [
        {
          "alias": false,
          "_styles": {
            "& when not (@sticky)": {
