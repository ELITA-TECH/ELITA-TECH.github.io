    "kontakt.html": {
      "settings": {
        "title": "Kontakt – serwis i automatyka przemysłowa | ELITA-TECH ŁÓDŹ",
        "order": "9",
        "meta_descr": "Naprawy maszyn i urządzeń przemysłowych, automatyka, sterowania PLC, instalacje elektryczne i modernizacje, systemy zabezpieczeń mienia. Szybka reakcja. Doświadczenie przemysłowe. Łódź i okolice."
