    "blog-przestoje-produkcji.html": {
      "settings": {
        "title": "Jak ograniczyć przestoje produkcyjne w zakładzie przemysłowym?",
        "order": "15",
        "meta_descr": "Przestoje produkcyjne generują realne straty finansowe. W wielu przypadkach można ich uniknąć dzięki właściwej strategii utrzymania ruchu oraz wdrożeniu nowoczesnych rozwiązań automatyki przemysłowej."
      },
